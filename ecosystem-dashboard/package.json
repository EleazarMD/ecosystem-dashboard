{
  "name": "ai-homelab-ecosystem-dashboard",
  "version": "2.0.0",
  "description": "AI Homelab Ecosystem Dashboard - Unified monitoring and management interface",
  "main": "next.config.js",
  "scripts": {
    "predev": "bash scripts/pre-dev-check.sh",
    "dev": "concurrently \"node server.js\" \"npx ts-node scripts/schema-sync-worker.ts\" \"node workers/audio-generation-worker.js\" \"bash scripts/start-goose-server.sh\" --names \"server,schema,audio,goose\" --prefix-colors \"cyan,magenta,yellow,blue\"",
    "dev:no-audio": "concurrently \"node server.js\" \"npx ts-node scripts/schema-sync-worker.ts\" \"bash scripts/start-goose-server.sh\" --names \"server,schema,goose\" --prefix-colors \"cyan,magenta,blue\"",
    "dev:server": "node server.js",
    "dev:nextonly": "next dev -p 8404",
    "dev:stable": "NEXT_DISABLE_TURBOPACK=1 NODE_OPTIONS=\"\" NEXT_TELEMETRY_DISABLED=1 next dev -p 8404",
    "build": "next build",
    "start": "next start -p 8404",
    "lint": "next lint",
    "dev:prod": "npm run build && npm run start",
    "test": "jest",
    "test:unit": "jest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "npm run test:unit && npm run test:e2e",
    "register-agent": "node src/scripts/register-agent.js",
    "upgrade-tier": "tsx scripts/upgrade-tier.ts",
    "agent:register": "node src/scripts/register-agent.js",
    "agent:health": "curl -s http://localhost:8404/api/agent/health | jq",
    "kg:start": "node scripts/real-kg-service-manager.js start",
    "kg:stop": "node scripts/real-kg-service-manager.js stop",
    "kg:restart": "node scripts/real-kg-service-manager.js restart",
    "kg:status": "node scripts/real-kg-service-manager.js status",
    "goose:start": "cd backend && python3 goose_api_server.py",
    "goose:stop": "pkill -f goose_api_server.py || true",
    "goose:restart": "npm run goose:stop && npm run goose:start",
    "goose:logs": "tail -f backend/goose.log",
    "goose:status": "curl -s http://localhost:9001/health | jq || echo 'Goose API server not running'",
    "status": "bash scripts/service-status.sh",
    "services:status": "bash scripts/service-status.sh",
    "mcp:start": "./scripts/start-mcp-services.sh",
    "mcp:stop": "./scripts/stop-mcp-services.sh",
    "mcp:restart": "npm run mcp:stop && npm run mcp:start",
    "figma:extract": "tsx scripts/design-system/figma-token-extractor.ts",
    "figma:map": "tsx scripts/design-system/component-mapper.ts ./design-tokens.json ./generated-theme",
    "figma:apply": "tsx scripts/design-system/theme-applier.ts ./design-tokens.json",
    "figma:audit": "tsx scripts/design-system/theme-applier.ts ./design-tokens.json --audit-only",
    "figma:pipeline": "npm run figma:extract && npm run figma:map && npm run figma:apply",
    "mcp:logs": "tail -f backend/mcp_services.log",
    "mcp:status": "ps aux | grep workspace-mcp-server | grep -v grep || echo 'No MCP services running'",
    "worker:audio": "node workers/audio-generation-worker.js",
    "worker:dev": "nodemon --watch workers workers/audio-generation-worker.js",
    "validate:schema": "ts-node scripts/validate-db-schema.ts",
    "db:validate": "ts-node scripts/validate-db-schema.ts",
    "sync:schema": "ts-node scripts/sync-schema-to-workspace.ts",
    "schema:sync": "ts-node scripts/sync-schema-to-workspace.ts",
    "schema:watch": "nodemon --watch database/migrations --exec npm run sync:schema",
    "schema:worker": "npx ts-node scripts/schema-sync-worker.ts",
    "schema:worker:once": "npx ts-node scripts/schema-sync-worker.ts --once",
    "schema:worker:dev": "nodemon --watch scripts scripts/schema-sync-worker.ts",
    "dev:local": "NODE_ENV=development next dev",
    "dev:cloud": "next dev",
    "sync-db": "./sync-production-data.sh"
  },
  "keywords": [
    "ai",
    "homelab",
    "agents",
    "orchestration",
    "multi-provider",
    "tripcraft"
  ],
  "author": "AI Homelab Ecosystem",
  "license": "MIT",
  "dependencies": {
    "@chakra-ui/icons": "^2.1.1",
    "@chakra-ui/react": "^2.8.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@google/generative-ai": "^0.24.1",
    "@heroicons/react": "^2.2.0",
    "@modelcontextprotocol/sdk": "^1.20.2",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@mui/x-data-grid": "^8.28.0",
    "@pipecat-ai/client-js": "^1.6.1",
    "@pipecat-ai/small-webrtc-transport": "^1.9.0",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@react-spring/web": "^10.0.3",
    "@svgr/webpack": "^8.1.0",
    "@tanstack/react-query": "^5.59.0",
    "@tavily/core": "^0.5.12",
    "@types/d3": "^7.4.3",
    "@types/formidable": "^3.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.7",
    "@types/multer": "^2.0.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.15.5",
    "@types/plotly.js": "^3.0.8",
    "@types/three": "^0.179.0",
    "@types/uuid": "^10.0.0",
    "adm-zip": "^0.5.16",
    "axios": "^1.11.0",
    "bootstrap": "^5.3.8",
    "chart.js": "^4.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "d3": "^7.9.0",
    "date-fns": "^3.6.0",
    "dompurify": "^3.3.3",
    "dotenv": "^17.2.1",
    "express": "^4.21.2",
    "file-saver": "^2.0.5",
    "form-data": "^4.0.5",
    "formidable": "^3.5.4",
    "framer-motion": "^10.18.0",
    "gray-matter": "^4.0.3",
    "html-to-image": "^1.11.13",
    "html2canvas": "^1.4.1",
    "http-proxy-middleware": "^3.0.5",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "lottie-react": "^2.4.1",
    "lottie-web": "^5.13.0",
    "lucide-react": "^0.539.0",
    "mammoth": "^1.11.0",
    "marked": "^17.0.5",
    "multer": "^2.0.2",
    "nanoid": "^5.1.6",
    "neo4j-driver": "^5.28.2",
    "next": "^14.2.15",
    "next-auth": "^4.24.13",
    "node-fetch": "^2.6.7",
    "nodemailer": "^8.0.1",
    "openai": "^6.5.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.16.3",
    "plotly.js-dist-min": "^3.2.0",
    "re-resizable": "^6.11.2",
    "react": "^19.1.1",
    "react-bootstrap": "^2.10.10",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^19.1.1",
    "react-feather": "^2.0.10",
    "react-force-graph-3d": "^1.28.0",
    "react-hot-toast": "^2.4.1",
    "react-icons": "^5.5.0",
    "react-intersection-observer": "^9.16.0",
    "react-markdown": "^10.1.0",
    "react-spring": "^10.0.3",
    "react-textarea-autosize": "^8.5.9",
    "react-toastify": "^11.0.5",
    "reactflow": "^11.11.4",
    "recharts": "^3.3.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.9.2",
    "rss-parser": "^3.13.0",
    "slate": "^0.118.1",
    "slate-dom": "^0.123.0",
    "slate-history": "^0.113.1",
    "slate-react": "^0.118.2",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "swr": "^2.2.5",
    "tailwind-merge": "^3.3.1",
    "three": "^0.179.1",
    "uuid": "^11.1.0",
    "web-push": "^3.6.7",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/preset-env": "^7.28.0",
    "@babel/preset-react": "^7.27.1",
    "@babel/preset-typescript": "^7.27.1",
    "@playwright/test": "^1.40.0",
    "@testing-library/jest-dom": "^6.1.0",
    "@testing-library/react": "^15.0.0",
